# ONE-DATA-STUDIO-LITE 环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# ============================================================
# 安全配置 (生产环境必须修改)
# ============================================================

# JWT 密钥 - 用于签名用户认证Token
# 生产环境必须设置为强随机字符串，建议32位以上
# 可以使用以下命令生成: openssl rand -hex 32
JWT_SECRET=your-strong-random-secret-key-here

# JWT Token 有效期(小时)，默认24小时
JWT_EXPIRE_HOURS=24

# Token刷新阈值(分钟)，Token在过期前多少分钟内可自动刷新
JWT_REFRESH_THRESHOLD_MINUTES=30

# 环境标识 (development/production)
# 生产环境设置为 production 会启用更严格的安全检查
ENVIRONMENT=development

# ============================================================
# 配置中心 (etcd)
# ============================================================

# etcd 服务地址，多个地址用逗号分隔
ETCD_ENDPOINTS=http://localhost:2379

# 是否启用配置中心
ENABLE_CONFIG_CENTER=true

# 配置缓存过期时间（秒）
CONFIG_CACHE_TTL=60

# 配置加密密钥（Base64 编码的 Fernet key）
# 用于加密存储在 etcd 中的敏感配置
# 可以使用以下命令生成: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONFIG_ENCRYPTION_KEY=

# ============================================================
# 用户认证配置
# ============================================================

# 开发环境用户配置 (JSON 格式)
# 生产环境建议集成 LDAP/OAuth 或使用数据库存储用户
# 格式: {"username": {"password": "xxx", "role": "admin", "display_name": "显示名"}}
# DEV_USERS={"admin": {"password": "your-secure-password", "role": "admin", "display_name": "管理员"}}

# ============================================================
# 外部平台认证Token
# ============================================================

# DataHub Personal Access Token
# 获取方式: DataHub Web UI → Settings → Access Tokens → Generate Personal Access Token
# 文档: https://datahubproject.io/docs/authentication/personal-access-tokens
PORTAL_DATAHUB_TOKEN=

# DataHub Webhook 签名密钥
# 用于验证来自 DataHub 的 Webhook 请求
# 需要在 DataHub 中配置相同的密钥
# 生产环境必须配置，可使用以下命令生成: openssl rand -hex 32
META_SYNC_DATAHUB_WEBHOOK_SECRET=

# DolphinScheduler Token
# 获取方式: DS Web UI → Security Center → Token Management → Create Token
# 文档: https://dolphinscheduler.apache.org/en-us/docs/latest/user_doc/guide/security.html
PORTAL_DOLPHINSCHEDULER_TOKEN=

# Superset Admin 凭据
# 用于Portal代理访问Superset API
# 注意: 建议创建专用服务账号，而非使用默认admin
PORTAL_SUPERSET_ADMIN_USER=admin
PORTAL_SUPERSET_ADMIN_PASSWORD=your-superset-password

# Superset 部署配置
SUPERSET_ADMIN_EMAIL=admin@onedata.local
SUPERSET_DB_PASSWORD=superset_change_in_production
SUPERSET_SECRET_KEY=one-data-studio-superset-secret-key-change-in-production
SUPERSET_LOG_LEVEL=INFO
SUPERSET_PORT=8088

# 内部服务通信 Token
# 用于服务间认证（如 sensitive_detect 调用 portal 的脱敏API）
# 可使用以下命令生成: openssl rand -hex 32
INTERNAL_TOKEN=

# ============================================================
# LLM 配置
# ============================================================

# LLM 服务地址 (Ollama API)
LLM_BASE_URL=http://localhost:31434

# LLM 模型名称
LLM_MODEL=qwen2.5:7b

# ============================================================
# 服务地址配置
# ============================================================

# 子系统地址
PORTAL_CUBE_STUDIO_URL=http://localhost:30080
PORTAL_SUPERSET_URL=http://localhost:8088
PORTAL_DATAHUB_URL=http://localhost:9002
PORTAL_DATAHUB_GMS_URL=http://localhost:8081
PORTAL_DOLPHINSCHEDULER_URL=http://localhost:12345
PORTAL_HOP_URL=http://localhost:8083

# SeaTunnel
PORTAL_SEATUNNEL_URL=http://localhost:5802

# SeaTunnel API Key（可选，用于 SeaTunnel 认证）
SEA_TUNNEL_API_KEY=

# 内部二开服务地址
PORTAL_NL2SQL_URL=http://localhost:8011
PORTAL_AI_CLEANING_URL=http://localhost:8012
PORTAL_METADATA_SYNC_URL=http://localhost:8013
PORTAL_DATA_API_URL=http://localhost:8014
PORTAL_SENSITIVE_DETECT_URL=http://localhost:8015
PORTAL_AUDIT_LOG_URL=http://localhost:8016

# ============================================================
# 其他配置
# ============================================================

# 服务端口
PORTAL_APP_PORT=8010

# Debug 模式 (生产环境设为 false)
PORTAL_DEBUG=false

# ShardingSphere 配置文件路径
PORTAL_SHARDINGSPHERE_CONFIG_PATH=deploy/shardingsphere/config/config-mask.yaml

# 数据库连接URL (如果使用数据库存储用户)
# DATABASE_URL=postgresql://user:password@localhost:5432/portal
