# ============================================================
# ONE-DATA-STUDIO-LITE 生产环境配置模板
# ============================================================
# 使用说明:
# 1. 复制此文件为 .env.production
# 2. 修改所有占位符值（包含 __CHANGE_ME__）
# 3. 运行: bash scripts/setup-production.sh
# 4. 确保 .env.production 权限正确: chmod 600 .env.production

# ============================================================
# 环境标识
# ============================================================
ENVIRONMENT=production
DEBUG=false

# ============================================================
# JWT 密钥（必须修改！）
# ============================================================
# 生成命令: openssl rand -hex 32
JWT_SECRET=__CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32__
JWT_EXPIRE_HOURS=24
JWT_REFRESH_THRESHOLD_MINUTES=30

# ============================================================
# 数据库配置（必须修改！）
# ============================================================
# 格式: mysql+pymysql://用户名:密码@主机:端口/数据库名
DATABASE_URL=mysql+pymysql://one_data_studio:__CHANGE_ME_PASSWORD__@mysql:3306/one_data_studio

# ============================================================
# Redis 配置（用于 Token 黑名单）
# ============================================================
REDIS_URL=redis://:@redis:6379/0
REDIS_BLACKLIST_DB=0

# ============================================================
# 服务间通信密钥（必须修改！）
# ============================================================
# 生成命令: openssl rand -hex 32
SERVICE_SECRET=__CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32__
INTERNAL_TOKEN=__CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32__

# ============================================================
# 配置中心加密密钥
# ============================================================
# 生成命令: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONFIG_ENCRYPTION_KEY=__CHANGE_ME_GENERATE_WITH_python_cryptography_fernet__
ETCD_ENDPOINTS=http://etcd:2379
ENABLE_CONFIG_CENTER=true
CONFIG_CACHE_TTL=60

# ============================================================
# 外部服务认证（必须修改！）
# ============================================================

# DataHub
# 在 DataHub 中生成 Personal Access Token
DATAHUB_TOKEN=__CHANGE_ME_GENERATE_IN_DATAHUB__
DATAHUB_GMS_URL=http://datahub-gms:8081
DATAHUB_URL=http://localhost:9002

# Superset
# 修改默认管理员凭据
SUPERSET_ADMIN_USER=__CHANGE_ME_USERNAME__
SUPERSET_ADMIN_PASSWORD=__CHANGE_ME_STRONG_PASSWORD__
SUPERSET_URL=http://localhost:8088

# DolphinScheduler
# 在 DS 中创建 Token
DOLPHINSCHEDULER_TOKEN=__CHANGE_ME_GENERATE_IN_DS__
DOLPHINSCHEDULER_URL=http://localhost:12345

# SeaTunnel
SEA_TUNNEL_API_KEY=__CHANGE_ME_GENERATE_IN_SEATUNNEL__
SEATUNNEL_URL=http://localhost:5802

# Apache Hop
HOP_URL=http://localhost:8083

# Cube-Studio
CUBE_STUDIO_URL=http://localhost:30080

# ============================================================
# 内部微服务地址
# ============================================================
NL2SQL_URL=http://localhost:8011
AI_CLEANING_URL=http://localhost:8012
METADATA_SYNC_URL=http://localhost:8013
DATA_API_URL=http://localhost:8014
SENSITIVE_DETECT_URL=http://localhost:8015
AUDIT_LOG_URL=http://localhost:8016

# ============================================================
# LLM 配置
# ============================================================
LLM_BASE_URL=http://ollama:11434
LLM_MODEL=qwen2.5:7b

# ============================================================
# 安全 Webhook 密钥
# ============================================================
# 生成命令: openssl rand -hex 32
META_SYNC_DATAHUB_WEBHOOK_SECRET=__CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32__

# ============================================================
# 开发环境用户配置（生产环境应使用数据库认证）
# ============================================================
# 格式为 JSON，不推荐在生产环境使用
# DEV_USERS='{"admin": {"password": "xxx", "role": "admin", "display_name": "管理员"}}'
