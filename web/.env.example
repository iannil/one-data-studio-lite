# ONE-DATA-STUDIO-LITE Frontend Environment Variables
# Copy this file to .env.local and configure values for your environment

# ============================================================================
# API Configuration
# ============================================================================

# Base URL for the portal API (default: http://localhost:8010)
VITE_API_BASE_URL=http://localhost:8010

# Individual microservice URLs (for direct access if needed)
VITE_PORTAL_URL=http://localhost:8010
VITE_NL2SQL_URL=http://localhost:8011
VITE_AI_CLEANING_URL=http://localhost:8012
VITE_METADATA_SYNC_URL=http://localhost:8013
VITE_DATA_API_URL=http://localhost:8014
VITE_SENSITIVE_DETECT_URL=http://localhost:8015
VITE_AUDIT_LOG_URL=http://localhost:8016

# ============================================================================
# Authentication Configuration
# ============================================================================

# Enable Cookie-based authentication (httpOnly Cookie) - recommended for production
# Set to 'false' to use localStorage-based token storage (less secure)
# VITE_USE_COOKIE_AUTH=true

# ============================================================================
# SSO Configuration
# ============================================================================

# Enterprise WeChat (WeCom) OAuth2 Client ID
# VITE_SSO_WEWORK_CLIENT_ID=wwxxxxxxxxxxxxxxxxxx

# DingTalk OAuth2 Client ID
# VITE_SSO_DINGTALK_CLIENT_ID=dingxxxxxxxxxxxxxxxxxx

# ============================================================================
# Feature Flags
# ============================================================================

# Enable/disable specific features (default: enabled)
# Set to 'false' to disable a feature

# VITE_FEATURE_NL2SQL=true
# VITE_FEATURE_DATA_API=true
# VITE_FEATURE_SENSITIVE_DATA=true
# VITE_FEATURE_AUDIT_LOG=true
# VITE_FEATURE_PIPELINE=true
