# ONE-DATA-STUDIO-LITE 环境变量配置
# 复制此文件为 .env 并修改配置值
# 警告: 生产环境必须修改所有 "changeme" 占位符

# ===========================================
# 通用配置 (必须设置)
# ===========================================

# 数据库连接 (MySQL)
DATABASE_URL=mysql+aiomysql://root:your_password_here@localhost:3306/one_data_studio

# MySQL 密码 (用于 DataHub/ShardingSphere)
MYSQL_PASSWORD=your_password_here
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=one_data_warehouse
MYSQL_USERNAME=root

# JWT 认证密钥 (请使用强随机字符串，至少32字符)
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars

# ===========================================
# 子系统地址
# ===========================================

# Cube-Studio
CUBE_STUDIO_URL=http://localhost:30080

# Apache Superset
SUPERSET_URL=http://localhost:8088
SUPERSET_SECRET_KEY=change-this-secret-key-in-production
SUPERSET_DATABASE_URI=mysql+pymysql://root:your_password_here@localhost:3306/superset
SUPERSET_ADMIN_PASSWORD=changeme

# DataHub
DATAHUB_GMS_URL=http://localhost:8081
DATAHUB_TOKEN=default-datahub-token-change-in-production

# DolphinScheduler
DOLPHINSCHEDULER_API_URL=http://localhost:12345/dolphinscheduler
DOLPHINSCHEDULER_TOKEN=default-ds-token-change-in-production

# ============================================================
# 邮件服务配置 (SMTP)
# ============================================================

# 是否启用邮件服务
SMTP_ENABLED=false

# SMTP 服务器配置
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# 发件人信息
SMTP_FROM_EMAIL=noreply@one-data-studio.local
SMTP_FROM_NAME=ONE-DATA-STUDIO-LITE

# 是否使用 TLS
SMTP_USE_TLS=true

# 连接超时时间（秒）
SMTP_TIMEOUT=30

# SeaTunnel
SEATUNNEL_API_URL=http://localhost:5801

# ShardingSphere
SHARDINGSPHERE_URL=http://localhost:3307
SHARDINGSPHERE_ROOT_PASSWORD=changeme
SHARDINGSPHERE_READONLY_PASSWORD=changeme

# ===========================================
# LLM 配置 (Ollama)
# ===========================================

LLM_BASE_URL=http://localhost:31434
LLM_MODEL=qwen2.5:7b
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# ===========================================
# 审计日志
# ===========================================

AUDIT_LOG_URL=http://localhost:8016/api/audit/log
AUDIT_LOG_RETENTION_DAYS=90

# ===========================================
# 各服务独立配置 (可选覆盖)
# ===========================================

# Portal
# PORTAL_APP_PORT=8010
# PORTAL_DATABASE_URL=...

# NL2SQL
# NL2SQL_APP_PORT=8011
# NL2SQL_DATABASE_URL=...

# AI Cleaning
# AI_CLEAN_APP_PORT=8012
# AI_CLEAN_DATABASE_URL=...

# Metadata Sync
# META_SYNC_APP_PORT=8013
# META_SYNC_DATABASE_URL=...

# Data API
# DATA_API_APP_PORT=8014
# DATA_API_DATABASE_URL=...

# Sensitive Detect
# SENSITIVE_APP_PORT=8015
# SENSITIVE_DATABASE_URL=...

# Audit Log
# AUDIT_APP_PORT=8016
# AUDIT_DATABASE_URL=...
