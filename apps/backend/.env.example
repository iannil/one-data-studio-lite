# Environment
DEBUG=false
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/smart_data

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=smart-data
MINIO_SECURE=false

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# Superset
SUPERSET_URL=http://superset:8088
SUPERSET_USERNAME=admin
SUPERSET_PASSWORD=admin

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ==============================================================================
# MLOps Configuration
# ==============================================================================

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
MLFLOW_ARTIFACT_ROOT=s3://mlflow/

# Model Serving
TF_SERVING_URL=http://tf-serving:8501
TF_SERVING_GRPC_URL=tf-serving:9000
TORCHSERVE_URL=http://torchserve:8080
TORCHSERVE_MANAGEMENT_URL=http://torchserve:8081
TRITON_URL=http://triton:8001

# Optuna
OPTUNA_STORAGE=postgresql://postgres:postgres@postgres:5432/optuna

# Ray
RAY_HEAD_ADDRESS=ray-head:10001
RAY_DASHBOARD_URL=http://ray-head:8265
